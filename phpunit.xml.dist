<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         failOnWarning="false"
         cacheDirectory=".phpunit.cache">
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>src</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <!-- Pin the default DB connection to the in-memory sqlite line the test
             suite defines. Pre-11 testbench lines reset database.default back to
             the framework default (mysql) after defineEnvironment(), which broke
             the host-DB residue probe; setting it here sticks on every line. -->
        <env name="DB_CONNECTION" value="testing"/>
        <ini name="error_reporting" value="22519"/>
    </php>
</phpunit>
