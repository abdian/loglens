{
    "name": "abdian/loglens",
    "description": "Production-scale log viewer for Laravel: persistent on-disk index, instant multi-GB opening, full-text search, browser live tail, error grouping, RTL. Laravel 8–13, PHP 8.0+, zero required extensions.",
    "keywords": [
        "laravel",
        "logs",
        "log-viewer",
        "monolog",
        "tail",
        "sqlite",
        "fts5",
        "observability"
    ],
    "homepage": "https://github.com/abdian/loglens",
    "license": "MIT",
    "authors": [
        {
            "name": "Ali Abdian",
            "homepage": "https://github.com/abdian",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/abdian/loglens/issues",
        "source": "https://github.com/abdian/loglens",
        "security": "https://github.com/abdian/loglens/security/policy"
    },
    "require": {
        "php": "^8.0",
        "illuminate/contracts": "^8.0|^9.0|^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^6.0|^7.0|^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^9.5|^10.5|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "LogLens\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LogLens\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "LogLens\\LogLensServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-text"
    }
}
